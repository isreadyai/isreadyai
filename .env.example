# ── isready.ai environment ─────────────────────────────────────────────
# Copy to .env and fill. Never commit .env.

# ── Supabase (apps/web) — new key naming (sb_publishable_* / sb_secret_*) ─
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# ── Social OAuth (Connect Google / Connect GitHub) — see docs/oauth-setup.md ─
# Providers are enabled in packages/supabase/config.toml; empty values keep
# `supabase start` working and simply leave the buttons inert. Fill these to go
# live. Local: paste here (and into .env.local). Hosted: set the same secrets in
# the Supabase dashboard (Authentication → Providers), NOT in this file.
#   GitHub → github.com/settings/developers → New OAuth App
#   Google → console.cloud.google.com → APIs & Services → Credentials → OAuth client ID
# OAuth-app callback URL to whitelist (provider side):
#   local  http://127.0.0.1:59321/auth/v1/callback
#   hosted https://<project-ref>.supabase.co/auth/v1/callback
SUPABASE_AUTH_GITHUB_CLIENT_ID=
SUPABASE_AUTH_GITHUB_SECRET=
SUPABASE_AUTH_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_GOOGLE_SECRET=
# X (OAuth 2.0 — the new provider; legacy 'twitter' OAuth 1.0a is deprecated):
# CLIENT_ID/SECRET are the X app's OAuth 2.0 Client ID & Client Secret
#   developer.x.com → Projects & Apps → your app → User authentication settings
SUPABASE_AUTH_X_CLIENT_ID=
SUPABASE_AUTH_X_SECRET=

# Auth Site URL — login redirect fallback + the value `supabase config push` ships
# to the hosted project. Local: https://localhost:3300. Hosted: https://isready.ai.
SUPABASE_AUTH_SITE_URL=https://localhost:3300

# ── Smart Agent Readability (agent-browser) ────────────────────────────
# local: install agent-browser globally; sandbox: use Vercel Sandbox.
AGENT_BROWSER_PROVIDER=local
AGENT_BROWSER_EXECUTABLE=agent-browser
AGENT_BROWSER_SNAPSHOT_ID=

# Local Vercel Sandbox auth. On Vercel, OIDC is automatic.
VERCEL_TOKEN=
VERCEL_TEAM_ID=
VERCEL_PROJECT_ID=

# ── Ask your site (premium, Vercel AI Gateway) ─────────────────────────
AI_GATEWAY_API_KEY=
SMART_AGENT_CHAT_MODEL=anthropic/claude-sonnet-4.6
# OpenAI-compatible base URL of the AI Gateway (override only when self-hosting).
AI_GATEWAY_BASE_URL=https://ai-gateway.vercel.sh/v1

# ── Premium fix action — in-runner AI agent via an ephemeral, metered token ─
# 32+ char secret that signs the short-lived solve tokens (fail-closed if unset).
SOLVE_TOKEN_SECRET=
# Model the inference proxy pins for solve runs.
SOLVE_MODEL=anthropic/claude-opus-4.8
# Model used to generate the AI fix plan (POST /api/fix-plan).
FIX_PLAN_MODEL=anthropic/claude-opus-4.8
# Pages (primary included) audited by the premium deep Smart Agent pass.
SMART_DEEP_PAGE_LIMIT=20
# Concurrent headless renders during the premium deep Smart Agent pass.
SMART_DEEP_CONCURRENCY=4

# ── Stripe (premium billing — Pro/Team subscriptions) ─────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRO_PRICE_ID=
STRIPE_TEAM_PRICE_ID=
# Seat model: default is a flat Team price with included seats + a hard limit.
# Set true only if the Team price is billed PER ACTIVE SEAT — then membership
# changes resize the Stripe subscription quantity.
STRIPE_PER_SEAT=false

# ── Email (Resend) — report delivery (PDF+MD to the visitor, lead saved) ─
# Without these, /api/email-report returns 503 and the UI falls back to downloads.
RESEND_API_KEY=
EMAIL_FROM="isready.ai <reports@isready.ai>"

# ── App ────────────────────────────────────────────────────────────────
# Canonical origin for metadata/sitemap/OG links. Local dev runs on :3300;
# code falls back to https://isready.ai when unset.
NEXT_PUBLIC_SITE_URL=http://localhost:3300
# Google Tag Manager container id (production only; leave empty to skip GTM).
NEXT_PUBLIC_GTM_ID=
# Stable 32+ character secret signing public Pro/Team badge URLs.
BADGE_SIGNING_SECRET=
# Dev-only API key for POST /api/fix when Supabase is not configured.
ISREADYAI_DEV_API_KEY=
# Max extra pages for the free in-browser deep scan on the report page.
NEXT_PUBLIC_DEEP_SCAN_LIMIT=10
# Per-IP/minute ceiling for the deep-scan fetch relay (/api/proxy).
PROXY_RATE_LIMIT=3000
# HMAC secret for scan-scoped proxy tokens (host-bound, 2h TTL). Set a strong
# random secret in production (e.g. openssl rand -hex 32).
PROXY_TOKEN_SECRET=dev-proxy-token-secret-change-in-production
# The known-insecure placeholder above: any deploy whose PROXY_TOKEN_SECRET still
# equals this value fails closed in production. Override only if you rotate the
# shipped placeholder itself.
PROXY_TOKEN_DEFAULT_SECRET=dev-proxy-token-secret-change-in-production
# Lifetime (ms) of host-bound proxy tokens and of the anonymous scan-write
# capability. Default 2h (7200000). Lower to shrink the replay window.
PROXY_TOKEN_TTL_MS=7200000
SCAN_WRITE_TOKEN_TTL_MS=7200000
# Min interval (ms) between last_used_at audit stamps on API-key verification,
# so a busy key doesn't write on every call. Default 5m (300000).
API_KEY_LAST_USED_THROTTLE_MS=300000

# Cloudflare Turnstile site key for the auth forms (public). Defaults to
# Cloudflare's documented "always passes" test key for local dev; set the real
# key in production. The matching secret lives in the Supabase auth config.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# Cloudflare Turnstile secret — the app verifies the contact form server-side.
# REQUIRED in production: server-side verification fails closed when this is unset
# in production, so a missing value blocks the form rather than silently passing.
# Local/dev may leave it empty (verification is skipped). Test secret: 1x0000000000000000000000000000000AA.
TURNSTILE_SECRET_KEY=

# Temporary gate for the HeroUI admin shell until full admin auth ships.
ENABLE_ADMIN_PREVIEW=false

# Secret guarding the scheduled re-scan cron (/api/cron/scan-domains). Vercel
# Cron sends it automatically as a Bearer token when this env var is set.
CRON_SECRET=
