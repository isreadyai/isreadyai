{
  "name": "isreadyai",
  "version": "1.0.6",
  "private": true,
  "description": "Is Ready for AI — audit whether a website or SaaS is readable, crawlable and optimized for LLMs and AI search engines.",
  "license": "SEE LICENSE IN LICENSE",
  "author": "Smart Squad S.r.l. (https://smartsquad.io)",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "postinstall": "bun run version:sync",
    "build": "turbo run build",
    "clean": "turbo run clean && rm -rf .turbo",
    "supabase": "sh -c 'if [ \"$#\" -eq 0 ]; then set -- --help; fi; bun run --cwd packages/supabase supabase \"$@\"' --",
    "db:deploy": "turbo run deploy:remote --filter=@isreadyai/supabase",
    "db:start": "turbo run start --filter=@isreadyai/supabase",
    "db:status": "turbo run status --filter=@isreadyai/supabase",
    "db:stop": "turbo run stop --filter=@isreadyai/supabase",
    "db:types": "turbo run generate:types:local --filter=@isreadyai/supabase",
    "dev:teardown": "bun run db:stop",
    "dev": "exits 'dotenv -- bun run scripts/dev.ts' 'bun run db:stop'",
    "dev:webhook": "bun run scripts/stripe-webhook.ts",
    "dev:cron": "bun run scripts/cron-dev.ts",
    "format:check": "oxfmt --check .",
    "format": "oxfmt .",
    "isreadyai": "bun run apps/cli/src/index.ts",
    "lint": "oxlint",
    "test": "turbo run test",
    "type-check": "turbo run type-check",
    "update-deps": "bun scripts/update-deps.ts",
    "version:check": "bun run scripts/sync-versions.ts --check",
    "version:sync": "bun run scripts/sync-versions.ts"
  },
  "dependencies": {
    "jose": "^6.2.3"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "exits": "^2.0.1",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.72.0",
    "turbo": "^2.10.3",
    "typescript": "~6.0.3"
  },
  "overrides": {
    "dompurify": "^3.4.11",
    "postcss": "^8.5.10",
    "undici": "^7.28.0"
  },
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=20.9.0"
  },
  "packageManager": "bun@1.3.14"
}
